								tooltip = "fnr_placeholder"
								size = { 400 32 }
								raw_text = "[SelectLocalization(And(Or(GetPlayer.HasVariable('fnr_historical_enabled'), GetPlayer.HasVariable('fnr_brandenburgprussia_enabled')), Not(GetPlayer.HasVariable('fnr_brandenburgprussia_disabled'))), 'Brandenburg-Prussia: ON', 'Brandenburg-Prussia: OFF')]"
								onclick = "[GetScriptedGui('FormableNationReworked_toggle_brandenburgprussia').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							}
