								onclick = "[GetScriptedGui('FormableNationReworked_toggle_assyria').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							}

							# Baden-Alsace - fantasy
							button_regular = {
								tooltip = "fnr_placeholder"
								size = { 400 32 }
								raw_text = "[SelectLocalization(And(Or(GetPlayer.HasVariable('fnr_fantasy_enabled'), GetPlayer.HasVariable('fnr_badenalsace_enabled')), Not(GetPlayer.HasVariable('fnr_badenalsace_disabled'))), 'Baden-Alsace: ON', 'Baden-Alsace: OFF')]"
								onclick = "[GetScriptedGui('FormableNationReworked_toggle_badenalsace').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							}

