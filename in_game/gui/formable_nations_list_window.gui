# Formable Nations Individual List Window
#
# Toggle for Historical Formables - fnr_historical_enabled
# Existed after EU5 start date and not after January 1, 1837
#
# Toggle for Non-Historical Formables - fnr_nonhistorical_enabled
# Existed before EU5 start date
#
# Toggle for Alt-History Formables - fnr_althistory_enabled
# nation that were proposed or exist in alternate timeline mods
#
# Toggle Fantasy Formables - fnr_fantasy_enabled
# Example: camelot, atlantis any unrealstic/made up country/story countries
#
# Toggle for Meme Formables - fnr_meme_enabled
# meme countries (Hyperborea, Agartha)
#
# Toggle for Modern Formables - fnr_modern_enabled
# Any nation existing after January 1, 1837 that isnt controversial
#
# Toggle for North America Formables - fnr_us_states_enabled
# Any nation within the North American Sphere (Canada, Mexico, US)
#

window = {
	name = "formable_nations_list_window"
	layer = windows_layer
	parentanchor = center
	size = { 800 600 }
	visible = "[GetVariableSystem.Exists('formable_list_window_open')]"
	using = bg_window_default_alt
	
	button_close_alt = {
		parentanchor = top|right
		position = { -15 15 }
		size = { 40 40 }
		blockoverride "close_onclick" {
			onclick = "[GetVariableSystem.Clear('formable_list_window_open')]"
		}
	}
	
	vbox = {
		margin = { 20 60 }
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding
		
		text_single = {
			raw_text = "Individual Formables List"
			using = header_font
			margin_bottom = 10
		}
		text_single = {
			raw_text = "NOTE: You may need to click the toggle a few times."
			using = header_font
			margin_bottom = 10
		}
		text_single = {
			raw_text = "It will cycle through (Cycle: Default → Force OFF → Force ON → Default)"
			using = header_font
			margin_bottom = 10
		}
		
		scrollbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			size = { 0 0 }
			
			blockoverride "scrollbox_content" {
				vbox = {
					layoutpolicy_horizontal = expanding
					spacing = 5
					margin = { 10 10 }

					# Rank 1 Formables
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 5
						
						button_main_tab_alt = {
							tooltip = "fnr_placeholder"
							using = layoutpolicy_expanding
							raw_text = "Rank I Formables"
							onclick = "[GetVariableSystem.Toggle('rank1_open')]"
							down = "[GetVariableSystem.Exists('rank1_open')]"
						}
						
						vbox = {
							layoutpolicy_horizontal = expanding
							visible = "[GetVariableSystem.Exists('rank1_open')]"
							spacing = 3
							margin = { 10 5 }
							
							# Pamiristan - Modern
							button_regular = {
								tooltip = "fnr_placeholder"
								size = { 400 32 }
								raw_text = "[SelectLocalization(And(Or(GetPlayer.HasVariable('fnr_pamiristan_enabled'), GetPlayer.HasVariable('fnr_pamiristan_enabled')), Not(GetPlayer.HasVariable('fnr_pamiristan_disabled'))), 'Pamiristan: ON', 'Pamiristan: OFF')]"
								onclick = "[GetScriptedGui('FormableNationReworked_toggle_pamiristan').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							}
						}
					}

					# Rank 2 Formables
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 5
						
						button_main_tab_alt = {
							tooltip = "fnr_placeholder"
							using = layoutpolicy_expanding
							raw_text = "Rank II Formables"
							onclick = "[GetVariableSystem.Toggle('rank2_open')]"
							down = "[GetVariableSystem.Exists('rank2_open')]"
						}
						
						vbox = {
							layoutpolicy_horizontal = expanding
							visible = "[GetVariableSystem.Exists('rank2_open')]"
							spacing = 3
							margin = { 10 5 }
							
							# Badakhshān - Modern
							button_regular = {
								tooltip = "fnr_placeholder"
								size = { 400 32 }
								raw_text = "[SelectLocalization(And(Or(GetPlayer.HasVariable('fnr_modern_enabled'), GetPlayer.HasVariable('fnr_badakhshan_enabled')), Not(GetPlayer.HasVariable('fnr_badakhshan_disabled'))), 'Badakhshān: ON', 'Badakhshān: OFF')]"
								onclick = "[GetScriptedGui('FormableNationReworked_toggle_badakhshan').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							}

							# Arpitania - Fantasy
							button_regular = {
								tooltip = "fnr_placeholder"
								size = { 400 32 }
								raw_text = "[SelectLocalization(And(Or(GetPlayer.HasVariable('fnr_fantasy_enabled'), GetPlayer.HasVariable('fnr_arpitania_enabled')), Not(GetPlayer.HasVariable('fnr_arpitania_disabled'))), 'Arpitania: ON', 'Arpitania: OFF')]"
								onclick = "[GetScriptedGui('FormableNationReworked_toggle_arpitania').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							}
